# AI测试学习项目环境变量配置示例
# 复制此文件为 .env 并填入你的实际值

# ===== LLM API Keys =====
# OpenAI API Key (用于阶段2-7)
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (用于阶段2-7)
# 获取地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ===== 可选配置 =====
# Redis配置（用于缓存，可选）
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ===== 测试配置 =====
# 跳过需要API Key的测试
# SKIP_API_TESTS=true

# 测试超时时间（秒）
# TEST_TIMEOUT=30

# ===== 日志配置 =====
# 日志级别: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# ===== 注意事项 =====
# 1. 请勿将 .env 文件提交到Git仓库
# 2. API Key 会产生费用，请注意使用
# 3. 建议使用测试账号的API Key
# 4. 大部分测试不需要API Key也能运行
